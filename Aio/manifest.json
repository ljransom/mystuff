{
  "name": "AIO",
  "id": "com.aiostreams.direct",
  "version": 1780506000,
  "url": "https://raw.githubusercontent.com/ljransom/mystuff/main/Aio/express.json",
  "type": "express",
  "accounts": [
    {
      "alias": "aio",

      "branding": {
        "name": "AioStreams (ELF)",
        "website": "https://aiostreams.elfhosted.com",
        "logo": "https://aiostreams.elfhosted.com/logo.png"
      },

      "auth": {
        "type": "basic"
      },

      "verification": {
        "url": "https://aiostreams.elfhosted.com/stremio/{managedAccounts.aio.username}/{managedAccounts.aio.password}/manifest.json",
        "method": "GET",
        "responseType": "json",

        "extract": {
          "username": {
            "type": "jsonpath",
            "value": "$.id"
          }
        }
      }
    }
  ]
}
